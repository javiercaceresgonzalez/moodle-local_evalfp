<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/evalfp/db" VERSION="20260629" COMMENT="XMLDB file for the local_evalfp plugin"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd"
>
  <TABLES>
    <TABLE NAME="local_evalfp_course_ra" COMMENT="Learning outcomes (RA) defined in a course">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="code" TYPE="char" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="description" TYPE="text" NOTNULL="true"/>
        <FIELD NAME="weight" TYPE="number" LENGTH="10" DECIMALS="5" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" UNSIGNED="true" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" UNSIGNED="true" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="courseid" TYPE="foreign" FIELDS="courseid" REFTABLE="course" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="courseid-code" UNIQUE="true" FIELDS="courseid, code"/>
      </INDEXES>
    </TABLE>

    <TABLE NAME="local_evalfp_course_ce" COMMENT="Evaluation criteria (CE) defined for course learning outcomes">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="courseraid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="code" TYPE="char" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="description" TYPE="text" NOTNULL="true"/>
        <FIELD NAME="weight" TYPE="number" LENGTH="10" DECIMALS="5" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" UNSIGNED="true" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" UNSIGNED="true" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="courseraid" TYPE="foreign" FIELDS="courseraid" REFTABLE="local_evalfp_course_ra" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="courseraid-code" UNIQUE="true" FIELDS="courseraid, code"/>
      </INDEXES>
    </TABLE>

    <TABLE NAME="local_evalfp_course_evaluation" COMMENT="Evaluation periods defined in a course">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="code" TYPE="char" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="description" TYPE="text" NOTNULL="true"/>
        <FIELD NAME="type" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="1" COMMENT="0=final, 1=partial, 2=extraordinary"/>
        <FIELD NAME="startdate" TYPE="int" LENGTH="10" UNSIGNED="true" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="enddate" TYPE="int" LENGTH="10" UNSIGNED="true" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" UNSIGNED="true" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" UNSIGNED="true" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="courseid" TYPE="foreign" FIELDS="courseid" REFTABLE="course" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="courseid-code" UNIQUE="true" FIELDS="courseid, code"/>
        <INDEX NAME="courseid-enddate-startdate" UNIQUE="false" FIELDS="courseid, enddate, startdate"/>
      </INDEXES>
    </TABLE>

    <TABLE NAME="local_evalfp_course_evidence_ce" COMMENT="Links gradebook evidence items with evaluation criteria">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="gradeitemid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="courseceid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" UNSIGNED="true" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" UNSIGNED="true" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="gradeitemid" TYPE="foreign" FIELDS="gradeitemid" REFTABLE="grade_items" REFFIELDS="id"/>
        <KEY NAME="courseceid" TYPE="foreign" FIELDS="courseceid" REFTABLE="local_evalfp_course_ce" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="gradeitemid-courseceid" UNIQUE="true" FIELDS="gradeitemid, courseceid"/>
      </INDEXES>
    </TABLE>

    <TABLE NAME="local_evalfp_course_evidence_evaluation" COMMENT="Assigns gradebook evidence items to course evaluations">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="gradeitemid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="courseevaluationid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" UNSIGNED="true" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" UNSIGNED="true" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="gradeitemid" TYPE="foreign" FIELDS="gradeitemid" REFTABLE="grade_items" REFFIELDS="id"/>
        <KEY NAME="courseevaluationid" TYPE="foreign" FIELDS="courseevaluationid" REFTABLE="local_evalfp_course_evaluation" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="gradeitemid" UNIQUE="true" FIELDS="gradeitemid"/>
      </INDEXES>
    </TABLE>


    <TABLE NAME="local_evalfp_course_settings" COMMENT="EvalFP settings defined for a course">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="showactivitycurriculum" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="activitycurriculumexpanded" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" UNSIGNED="true" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" UNSIGNED="true" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="courseid" TYPE="foreign" FIELDS="courseid" REFTABLE="course" REFFIELDS="id"/>
      </KEYS>
    </TABLE>
  </TABLES>
</XMLDB>
